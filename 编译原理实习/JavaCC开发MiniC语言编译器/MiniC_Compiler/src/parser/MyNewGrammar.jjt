SimpleNode Start() :
{}
{
  Program()
  {
    return jjtThis;
  }
}

//łĚĐň
void Program() :
{}
{
  Type() "main" "(" ")" "{"
  (
    SentenceBlock()
  )*
  "}"
}

//±í´ďĘ˝
String Expression() :
{
  String s = null;
}
{
  s = AdditiveExpression()
  {
    return s;
  }
}

String AdditiveExpression() :
{
  String a = null;
  String b = null;
  String result = null;
  Token t = null;
}
{
  a = MultiplicativeExpression()
  {
    result = a;
  }
  (
    (
      t = "+"
    | t = "-"
    )
    b = MultiplicativeExpression()
    {
      result = VariableNameGenerator.genVariableName();
      QTInfo qtInfo = new QTInfo(t.image, a, b, result);
      qtTable.addQTInfo(qtInfo);
      a = result;
    }
  )*
  {
    return result;
  }
}

String MultiplicativeExpression() :
{
  String a = null;
  String b = null;
  String result = null;
  Token t = null;
}
{
  a = UnaryExpression()
  {
    result = a;
  }
  (
    (
      t = "*"
    | t = "/"
    | t = "%"
    )
    b = UnaryExpression()
    {
      result = VariableNameGenerator.genVariableName();
      QTInfo qtInfo = new QTInfo(t.image, a, b, result);
      qtTable.addQTInfo(qtInfo);
      a = result;
    }
  )*
  {
    return result;
  }
}

String UnaryExpression() :
{
  String s = null;
  Token t = null;
}
{
  (
    "(" s = Expression() ")"
  | (
      t = Identifier()
      {
	    s = t.image;
        if(this.checkExsit(t.image) == false)
        {
          errorList.add(t.endLine + "ĐĐ" + t.endColumn + "ÁĐŁş" + "±äÁż"
          + t.image + "Î´¶¨Ňĺ");
        }
      }
    )
  | s = Integer()
  )
  {
    return s;
  }
}

//ŔŕĐÍ
String Type() :
{
  String s = null;
}
{
  s = < TYPE >.image
  {
    return s;
  }
}

//±ęĘ¶·ű
Token Identifier() :
{
  Token t = null;
}
{
  t = < IDENTIFIER >
  {
    return t;
  }
}

//ąŘĎµ±í´ďĘ˝
void RelationalOperator() :
{}
{
  < RELATIONAL_OPERATOR >
}

String Integer() :
{
  Token t = null;
}
{
  t = < INTEGER_LITERAL >
  {
    return t.image;
  }
}

void SentenceBlock() :
{}
{
  Sentence()
| ("{"
  (
    SentenceBlock()
  )*
  "}")
}

//Óďľä
void Sentence() :
{}
{
  seqSentence()
| conSentence()
| whileSentence()
| doWhileSentence()
| forSentence()
| switchSentence()
}


//ÂßĽ­±í´ďĘ˝Ł¬°´ÔËËăËłĐňŁ¬´ÓÂßĽ­»ňżŞĘĽĘ¶±đ
ConditionValue logExpression() :
{
  ConditionValue cValue = new ConditionValue();
}
{
  cValue = orExpression()
  {
    return cValue;
  }
}

//ÂßĽ­»ň
ConditionValue orExpression() :
{
  ConditionValue cValue1 = new ConditionValue();
  ConditionValue cValue2 = new ConditionValue();
}
{
  cValue1 = andExpression()
  {
    cValue2 = cValue1;
  }
  (
    "||"
    {
      cValue1.backpatchFalseChain(QTInfo.innerIdSeqen + 1);
    }
    cValue2 = andExpression()
    {
	  cValue2.trueChain.addAll(cValue1.trueChain);
      cValue1 = cValue2;
    }
  )*
  {
    return cValue2;
  }
}

//ÂßĽ­Óë
ConditionValue andExpression() :
{
  ConditionValue cValue1 = new ConditionValue();
  ConditionValue cValue2 = new ConditionValue();
}
{
  cValue1 = notExpression()
  {
    cValue2 = cValue1;
  }
  (
    "&&"
    {
      cValue1.backpatchTrueChain(QTInfo.innerIdSeqen + 1);
   	}
    cValue2 = notExpression()
    {
	  cValue2.falseChain.addAll(cValue1.falseChain);
      cValue1 = cValue2;
    }
  )*
  {
    return cValue2;
  }
}

//ÂßĽ­·Ç
ConditionValue notExpression() :
{
  ConditionValue cValue1 = new ConditionValue();
  ConditionValue cValue2 = new ConditionValue();
  boolean flag = true;
}
{
  ("!"
  {
    flag = false;
  })?
  cValue2 = relationalExpression()
  {
    if(flag)
    {
      cValue1.trueChain = cValue2.trueChain;
      cValue1.falseChain = cValue2.falseChain;
    }
    else
    {
      cValue1.trueChain = cValue2.falseChain;
      cValue1.falseChain = cValue2.trueChain;
    }
    return cValue1;
  }
}

//ąŘĎµ±í´ďĘ˝
ConditionValue relationalExpression() :
{
  Token t = null;
  String e1 = null;
  String e2 = null;
  ConditionValue cValue = new ConditionValue();
}
{
  e1 = Expression()
  (
    t = < RELATIONAL_OPERATOR > 
    e2 = Expression()
  )*
  {
    if (t == null)
    {
      QTInfo qtInfo = new QTInfo("jnz", e1, "_", "T");
      qtTable.addQTInfo(qtInfo);
      cValue.mergeTrue(qtInfo);
    }
    else
    {
      QTInfo qtInfo = new QTInfo("j" + t.image, e1, e2, "T");
      qtTable.addQTInfo(qtInfo);
      cValue.mergeTrue(qtInfo);
    }
    QTInfo qtInfo = new QTInfo("j", "_", "_", "F");
    qtTable.addQTInfo(qtInfo);
    cValue.mergeFalse(qtInfo);
  }
  {
    return cValue;
  }
}	

void conSentence() :
{
  ConditionValue cValue = new ConditionValue();
  int index = 0;
}
{
  "if" "(" cValue = logExpression() ")"
  {
    cValue.backpatchTrueChain(QTInfo.innerIdSeqen + 1);
  }
  SentenceBlock()
  {
    cValue.backpatchFalseChain(QTInfo.innerIdSeqen + 1);
  }
  (
    LOOKAHEAD(1)
    "else"
    {
      QTInfo qtInfo = new QTInfo("j", "_", "_", "");
      qtTable.addQTInfo(qtInfo);
      index = QTInfo.innerIdSeqen;
      cValue.backpatchFalseChain(QTInfo.innerIdSeqen + 1);
    }
    SentenceBlock()
    {
	  qtInfo = qtTable.get(index - 1);
      qtInfo.setResult(QTInfo.innerIdSeqen + 1);
    }
  )?
}

void LogicalOperators() :
{}
{
  (
    "&&"
  | "||"
  | "!"
  )
}

//whileŃ­»·Óďľä
void whileSentence() :
{
  ConditionValue cValue = new ConditionValue();
  int index = 0;
}
{
  "while" "("
    {
      index = QTInfo.innerIdSeqen + 1;
    }
    cValue = logExpression()
  ")"
  {
    cValue.backpatchTrueChain(QTInfo.innerIdSeqen + 1);
  }
  SentenceBlock()
  {
    QTInfo qtInfo = new QTInfo("j", "_", "_", index);
    qtTable.addQTInfo(qtInfo);
    cValue.backpatchFalseChain(QTInfo.innerIdSeqen + 1);
  }
}

//dowhileŃ­»·Óďľä
void doWhileSentence() :
{
  ConditionValue cValue = new ConditionValue();
  int index = 0;
}
{
  "do"
  {
    index = QTInfo.innerIdSeqen + 1;
  }
  SentenceBlock()
  "while" "(" cValue = logExpression() ")"
  {
    cValue.backpatchTrueChain(index);
    cValue.backpatchFalseChain(QTInfo.innerIdSeqen + 1);
  }";"
}

//×ÔÔö×ÔĽőĘ¶±đŁ¬Ö÷ŇŞÓĂÓÚforŃ­»·
void selfDeal() :
{
  Token op = null;
  Token e = null;
  String t = null;
}
{
  (
	  (
	    e = Identifier()
	    (
	      op = "++"
	    | op = "--"
	    )
	  )
	|
	  (
	    (	      op = "++"
	    | op = "--"
	    )
	    e = Identifier()
	  )
  )
  {
	System.out.println("do");
    if(this.checkExsit(e.image) == false)
    {
      errorList.add(e.endLine + "ĐĐ" + e.endColumn + "ÁĐŁş" + "±äÁż"
      + e.image + "Î´¶¨Ňĺ");
    }
	t = VariableNameGenerator.genVariableName();
    QTInfo qtInfo = new QTInfo(op.image.substring(0, 1), "1", e.image, t);
    qtTable.addQTInfo(qtInfo);
    qtInfo = new QTInfo("=", t, "_", e.image);
    qtTable.addQTInfo(qtInfo);
  }
}

//forŃ­»·Óďľä
void forSentence() :
{
  ConditionValue cValue = new ConditionValue();
  int result1 = 0;
  int result2 = 0;
}
{
  "for" "("
  (
    decSentence()
  | assSentence()
  )? ";"
  {
    result1 = QTInfo.innerIdSeqen + 1;
  }
  (cValue = logExpression()
   {
     result2 = QTInfo.innerIdSeqen + 1;
   })? ";"
  
  (
    LOOKAHEAD(2)
    selfDeal()
    {
      QTInfo qtInfo = new QTInfo("j", "_", "_", result1);
      qtTable.addQTInfo(qtInfo);
    }
  | assSentence()
  )?
  ")"
  {
    cValue.backpatchTrueChain(QTInfo.innerIdSeqen + 1);
  }
  SentenceBlock()
  {
    QTInfo qtInfo = new QTInfo("j", "_", "_", result2);
    qtTable.addQTInfo(qtInfo);
    cValue.backpatchFalseChain(QTInfo.innerIdSeqen + 1);
  }
}

//switchŃˇÔńÓďľä
void switchSentence() :
{
  String e1 = null;
  String e2 = null;
  int index = 0;
  int last = 0;
  boolean flag = false;
  ConditionValue cValue = new ConditionValue();
}
{
  "switch" "(" e1 = Expression() ")" 
  "{"
    (
      "case" e2 = Expression() ":"
      {
        QTInfo qtInfo = new QTInfo("jne", e1, e2, "");
        qtTable.addQTInfo(qtInfo);
        index = QTInfo.innerIdSeqen;
      }
      (
        SentenceBlock()
      )*
      {
		if(flag == false)
		{
		  cValue.backpatchFalseChain(index + 1);
		  cValue.clearFalse();
		}
		flag = false;
		
        qtInfo = new QTInfo("j", "_", "_", "");
        qtTable.addQTInfo(qtInfo);
        qtInfo = qtTable.get(index - 1);
        qtInfo.setResult(QTInfo.innerIdSeqen + 1);
        
        index = QTInfo.innerIdSeqen;
      }
      (        "break;"
        {
          flag = true;
        }
      )?
      {
        qtInfo = qtTable.get(index - 1);
        if(flag == true)
        {
          cValue.mergeTrue(qtInfo);
        }
        else
        {
          cValue.mergeFalse(qtInfo);
        }
      }
    )*
    ("default" ":"
    SentenceBlock())?
    {
      cValue.backpatchTrueChain(QTInfo.innerIdSeqen + 1);
    }
  "}"
}
//ËłĐňÓďľä
void seqSentence() :
{}
{
  (
    decSentence()
  | LOOKAHEAD(2)
    assSentence()
  | selfDeal()
  ) ";"
}

//ÉůĂ÷Óďľä
void decSentence() :
{
  String type = null;
  Token t = null;
  String e;
}
{
  type = Type()
  t = Identifier()
  {
    if(this.checkExsit(t.image))
    {
      errorList.add(t.endLine + "ĐĐ" + t.endColumn +"ÁĐŁş" + "±äÁż"
      + t.image + "ÖŘ¸´¶¨Ňĺ");
    }
    else
    {
	  t.type = type;
      tokenList.add(t);
    }
  }
  (
    "=" e = Expression()
    {
      QTInfo qtInfo = new QTInfo("=", e, "_", t.image);
      qtTable.addQTInfo(qtInfo);
    }
  )?
  (
    "," t = Identifier()
    {
      if(this.checkExsit(t.image))
      {
        errorList.add(t.endLine + "ĐĐ" + t.endColumn +"ÁĐŁş" + "±äÁż"
        + t.image + "ÖŘ¸´¶¨Ňĺ");
      }
      else
      {
	    t.type = type;
        tokenList.add(t);
      }
    }
    (
      "=" e = Expression()
      {
        QTInfo qtInfo = new QTInfo("=", e, "_", t.image);
        qtTable.addQTInfo(qtInfo);
      }
    )?
  )*
}

//¸łÖµÓďľä
void assSentence() :
{
  String arg1 = null;
  Token result = null;
}
{
  result = Identifier() 
  "=" 
  arg1 = Expression()
  {
    if(this.checkExsit(result.image) == false)
    {
      errorList.add(result.endLine + "ĐĐ" + result.endColumn + "ÁĐŁş" + "±äÁż"
      + result.image + "Î´¶¨Ňĺ");
    }
    QTInfo qtInfo = new QTInfo("=", arg1, "_", result.image);
    qtTable.addQTInfo(qtInfo);
  }
}
