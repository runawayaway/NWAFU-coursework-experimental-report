import java.util.Iterator;

import util.*;

public class MyNewGrammar
{
  static public QTTable qtTable = new QTTable();

  public static ArrayList < String > errorList = new ArrayList < String > ();

  public static ArrayList < Token > tokenList = new ArrayList < Token > ();
  
  public void printQTList()
  {
    qtTable.printQTTable();
  }
  public static void main(String args [])
  {
    try
    {
      InputStream in = new FileInputStream("Input.txt"); //ÓëĎîÄżÎÄĽţĽĐĎÂµÄInput.txtÎÄĽţ˝¨Á˘ĘäČëÁ÷
      OutputStream out = new FileOutputStream("Output.txt"); //ÓëĎîÄżÎÄĽţĽĐĎÂµÄOutput.txtÎÄĽţ˝¨Á˘ĘäłöÁ÷
      MyNewGrammarTokenManager manager = new MyNewGrammarTokenManager(new SimpleCharStream(in));//Í¨ąýJavaCC×Ô´řµÄÁ˝¸öŔŕ˝řĐĐĘýľÝµÄĘäČë
      Token t;
      t = manager.getNextToken();//Í¨ąýgetNextToken»ńČˇĘýľÝ
      while(t.kind != 0) {//µ±¶Áµ˝ĘýľÝµÄ˝áÎ˛Ł¬Ľ´EOFĘ±Ł¬ĆäÄÚ˛żµÄ±ęĘ¶·űÎŞ0Ł¬ËůŇÔŇÔ´ËÎŞ˝áĘř±ęÖľ
	  	out.write(("(" + t.kind + ", " + t.image + ")\n").getBytes());//ĘäłöÄÚ˛ż±ęĘ¶·űÓë×ÔÉí
        t = manager.getNextToken();
      }
      in.close();
      in = new FileInputStream("Input.txt");//ąŘ±Ő˛˘ÖŘĐÂ˝¨Á˘ĘäłöÁ÷Ł¬ŇÔÖŘÖĂ¶ÁČˇ˝ř¶Č
      MyNewGrammar parser = new MyNewGrammar(in);
      SimpleNode n = parser.Start();
      n.dump("", out); //ĘąÓĂÖŘÔŘşóµÄ·ÖÎöłĚĐň
      out.write("\n".getBytes());
      qtTable.printQTTable(out);
      System.out.println("Thank you.");
      in.close();
      out.close();
    }
    catch (Exception e)
    {
      System.out.println("Oops.");
      System.out.println(e.getMessage());
    }
  }

  public static void dealData(String filename)
  {
	VariableNameGenerator.sequenceId = 0;//˝řĐĐĘýľÝµÄłőĘĽ»Ż
	errorList.clear();
	tokenList.clear();
	qtTable.clear();
    try
    {
      InputStream in = new FileInputStream(filename); //Ö¸¶¨ÎÄĽţ˝¨Á˘ĘäČëÁ÷
      OutputStream out = new FileOutputStream("Output.txt"); //ÓëĎîÄżÎÄĽţĽĐĎÂµÄOutput.txtÎÄĽţ˝¨Á˘ĘäłöÁ÷
      MyNewGrammarTokenManager manager = new MyNewGrammarTokenManager(new SimpleCharStream(in));//Í¨ąýJavaCC×Ô´řµÄÁ˝¸öŔŕ˝řĐĐĘýľÝµÄĘäČë
      Token t;
      t = manager.getNextToken();//Í¨ąýgetNextToken»ńČˇĘýľÝ
      while(t.kind != 0) {//µ±¶Áµ˝ĘýľÝµÄ˝áÎ˛Ł¬Ľ´EOFĘ±Ł¬ĆäÄÚ˛żµÄ±ęĘ¶·űÎŞ0Ł¬ËůŇÔŇÔ´ËÎŞ˝áĘř±ęÖľ
	  	out.write(("(" + t.kind + ", " + t.image + ")\n").getBytes());//ĘäłöÄÚ˛ż±ęĘ¶·űÓë×ÔÉí
        t = manager.getNextToken();
      }
      in.close();
      in = new FileInputStream("Input.txt");//ąŘ±Ő˛˘ÖŘĐÂ˝¨Á˘ĘäłöÁ÷Ł¬ŇÔÖŘÖĂ¶ÁČˇ˝ř¶Č
      MyNewGrammar parser = new MyNewGrammar(in);
      SimpleNode n = parser.Start();
      n.dump("", out); //ĘąÓĂÖŘÔŘşóµÄ·ÖÎöłĚĐň
      out.write("\n".getBytes());
      qtTable.printQTTable(out);
      out.write("\n".getBytes());
  	  Iterator<Token> itr =  tokenList.iterator();
	  while(itr.hasNext())
	  {
	    Token tmp = (Token) itr.next();
		out.write((tmp.showInfo() + "\n").getBytes());//ĎňÎÄĽţÖĐĐ´Čë·űşĹ±í
	  }
      in.close();
      out.close();
    }
    catch (Exception e)
    {
      errorList.add(e.getMessage());
    }
  }
  boolean checkExsit(String image)
  {
    if(tokenList.isEmpty() == true) return false;
    Iterator<Token> itr = tokenList.iterator();
	while(itr.hasNext())
	{
	  Token tmp = (Token) itr.next();
	  if(tmp.image.equals(image))
	  {
	    return true;
	  }
	}
	return false;
  }
}

PARSER_END(MyNewGrammar)

SKIP :
{
  " "
| "\t"
| "\n"
| "\r"
| < "//" (~[ "\n", "\r" ])*
    (
      "\n"
    | "\r"
    | "\r\n"
    ) >
| < "/*" (~[ "*" ])* "*"
    (
      ~[ "/" ] (~[ "*" ])* "*"
    )*
    "/" >
}

TOKEN : /* LITERALS */
{
  < INTEGER_LITERAL :
    < DECIMAL_LITERAL > ([ "l", "L" ])?
  | < HEX_LITERAL > ([ "l", "L" ])?
  | < OCTAL_LITERAL > ([ "l", "L" ])? 
  >
| < #DECIMAL_LITERAL : ( "0" | ([ "1"-"9" ] ([ "0"-"9" ])*))("." ([ "0"-"9" ])*)? >
| < #HEX_LITERAL : "0" [ "x", "X" ] ([ "0"-"9", "a"-"f", "A"-"F" ])+ >
| < #OCTAL_LITERAL : "0" ([ "0"-"7" ])* >
}

TOKEN : /* special signal */
{
  < MAIN : "main" >
}

TOKEN : /* keyword */
{
  < IF : "if" >
| < ELSE : "else" >
| < WHILE : "while" >
| < DO : "do" >
| < FOR : "for" >
| < SWITCH : "switch" >
| < SDEFAULT : "default" >
| < CASE : "case" >
| < TURE : "ture" >
| < FALSE : "false" >
}

TOKEN : /* operators */
{
  < ADD : "+" >
| < MUL : "*" >
| < DIV : "/" >
| < MINUS : "-" >
| < MOD : "%" >
| < EQL : "=" >
| < SELFADD : "++" >
| < SELFMINUS : "--" >
}

TOKEN : /*LogicalOperators*/
{
  < AND : "&&" >
| < OR : "||" >
| < NOT : "!" >
}

TOKEN : /*relational operatorŁ¬ÓĂÓÚ˛Ľ¶ű±í´ďĘ˝µÄĘ¶±đ*/
{
  < RELATIONAL_OPERATOR :
    < REQL >
  | < UEQL >
  | < LT >
  | < LTE >
  | < RT >
  | < RTE > 
  >
| < #REQL : "==" >
| < #UEQL : "!=" >
| < #LT : "<" >
| < #LTE : "<=" >
| < #RT : ">" >
| < #RTE : " >=" >
}

TOKEN : //±äÁżŔŕĐÍ,ÓĂÓÚÉůĂ÷ÓďľäµÄĘąÓĂ
{
  < TYPE :
    < VOID >
  | < INT >
  | < FLOAT >
  | < CHAR >
  | < STRING >
  >
| < #VOID : "void" >
| < #INT : "int" >
| < #LONGLONG : "long long" >
| < #FLOAT : "float" >
| < #DOUBLE : "double" >
| < #CHAR : "char" >
| < #STRING : "string" >
}

TOKEN : /* separators */
{
  < SEMI : ";" >
| < COMMA : "," >
| < LB : "{" >
| < RB : "}" >
| < LBK : "[" >
| < RBK : "]" >
| < LP : "(" >
| < RP : ")" >
}

TOKEN : /* IDENTIFIERS */
{
  < IDENTIFIER :
    < LETTER >
    (
      < LETTER >
    | < DIGIT >
    )* >
| < #LETTER : [ "_", "a"-"z", "A"-"Z" ] >
| < #DIGIT : [ "0"-"9"] >
}



